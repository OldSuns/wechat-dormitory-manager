.edit-popup {
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 85vh;
  width: 100vw;
  box-sizing: border-box;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.edit-popup__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.edit-popup__title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.edit-popup__close {
  padding: 8rpx;
}

.edit-popup__body {
  padding: 24rpx 32rpx;
  max-height: 65vh;
  box-sizing: border-box;
  width: 100%;
}

.edit-popup__field {
  margin-bottom: 28rpx;
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
}

.edit-popup__label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.edit-popup__date {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
}

.edit-popup__actions {
  padding: 24rpx 0 48rpx;
}
