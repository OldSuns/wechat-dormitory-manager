.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.student-tabs { background: #fff; }
.floor-tabs { background: #fff; margin-top: 4rpx; }

.tab-content { padding: 20rpx 24rpx; }

/* 我的床位卡片 */
.my-bed-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  border-left: 6rpx solid #0052d9;
}

.my-bed-card__title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}

.my-bed-card__info { padding-bottom: 16rpx; }

.my-bed-card__row {
  display: flex;
  justify-content: space-between;
  padding: 10rpx 0;
}

.my-bed-card__label { font-size: 26rpx; color: #999; }
.my-bed-card__value { font-size: 26rpx; color: #333; }

.my-bed-card__action {
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

/* 统计栏 */
.summary-bar {
  display: flex;
  justify-content: space-around;
  background: #fff;
  padding: 24rpx 16rpx;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.summary-item { display: flex; flex-direction: column; align-items: center; }
.summary-value { font-size: 40rpx; font-weight: 700; color: #333; }
.summary-value--green { color: #2ba471; }
.summary-label { font-size: 22rpx; color: #999; margin-top: 6rpx; }

/* 房间网格 */
.room-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 0 24rpx;
}
.room-grid__item { width: 100%; }

.empty-hint {
  text-align: center; padding: 120rpx 0; color: #999; font-size: 28rpx;
}

/* Tab4: 设置 */
.profile-card {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 40rpx 32rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 20rpx;
}

.avatar-btn {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  padding: 0;
  margin: 0 28rpx 0 0;
  border: none;
  background: transparent;
  border-radius: 50%;
  overflow: visible;
  line-height: normal;
  flex-shrink: 0;
}

.avatar-btn::after {
  display: none;
}

.profile-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
}

.profile-avatar--placeholder {
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-edit-badge {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.profile-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}

.profile-name-input {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  width: 100%;
}

.section-title {
  font-size: 26rpx;
  color: #999;
  padding: 20rpx 0 12rpx 8rpx;
}

.logout-cell {
  --td-cell-title-color: #d54941;
}

.footer-hint {
  text-align: center;
  font-size: 24rpx;
  color: #bbb;
  padding: 48rpx 0;
}

.rebind-body {
  padding: 16rpx 24rpx;
}

.rebind-hint {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.rebind-error {
  font-size: 24rpx;
  color: #d54941;
  margin-top: 12rpx;
}

.edit-dialog-body {
  padding: 16rpx 24rpx;
}
