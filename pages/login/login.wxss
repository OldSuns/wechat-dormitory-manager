.login-page {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 48rpx;
}

.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
  margin-bottom: 80rpx;
}

.login-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #333;
  margin-top: 24rpx;
}

.login-subtitle {
  font-size: 26rpx;
  color: #999;
  margin-top: 12rpx;
}

.login-body {
  width: 100%;
}

.login-field {
  margin-bottom: 32rpx;
}

.login-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.login-error {
  color: #d54941;
  font-size: 26rpx;
  margin-bottom: 24rpx;
  text-align: center;
}

.login-hint {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 24rpx;
}
