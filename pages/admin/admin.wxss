.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.admin-tabs {
  background: #fff;
}

.tab-content {
  padding: 20rpx 24rpx;
}

/* 选择器行 */
.selector-row {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 24rpx 32rpx;
  gap: 32rpx;
}

.selector-item {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.selector-label {
  font-size: 28rpx;
  color: #666;
  white-space: nowrap;
}

.selector-value {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
}

/* 统计栏 */
.summary-bar {
  display: flex;
  justify-content: space-around;
  background: #fff;
  padding: 24rpx 16rpx;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
}

.summary-value--green { color: #2ba471; }
.summary-value--orange { color: #e37318; }

.summary-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

/* 房间网格 */
.room-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 0 24rpx;
}

.room-grid__item { width: 100%; }

.empty-hint {
  text-align: center;
  padding: 120rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* Tab2: 房间管理 */
.mgmt-header-compact {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  padding: 20rpx 32rpx;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.compact-filter {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.compact-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.compact-picker {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
  min-width: 160rpx;
}

.compact-actions {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.icon-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.icon-btn:active {
  background: #e8e8e8;
  transform: scale(0.95);
}

.icon-btn--primary {
  background: #e6f0ff;
}

.icon-btn--primary:active {
  background: #cce0ff;
}

.room-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.room-mgmt-cell {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  min-height: 100rpx;
  box-sizing: border-box;
}

.room-mgmt-cell__left {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.room-mgmt-cell__name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.room-mgmt-cell__floor {
  font-size: 24rpx;
  color: #999;
}

.room-mgmt-cell__right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}

.room-mgmt-cell__bed-info {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.room-mgmt-cell__label {
  font-size: 22rpx;
  color: #999;
}

/* 侧滑按钮样式 */
.btn-edit {
  background-color: #0052d9 !important;
  color: #fff !important;
  line-height: 100rpx !important;
}

.btn-delete {
  background-color: #d54941 !important;
  color: #fff !important;
  line-height: 100rpx !important;
}

/* Tab3: 申请审批 */
.app-count-hint {
  font-size: 26rpx;
  color: #e37318;
  margin-bottom: 16rpx;
}

/* 添加房间弹窗 */
.add-dialog-body {
  padding: 24rpx;
}

/* 编辑房间弹窗 */
.edit-dialog-body {
  padding: 24rpx;
}

.add-dialog-field {
  margin-bottom: 24rpx;
}

.add-dialog-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.add-dialog-floor {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #f5f5f5;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
}

/* 导入数据弹窗 */
.import-dialog-body {
  padding: 24rpx 24rpx 12rpx;
}

.import-mode-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
  display: block;
}

.import-hint {
  margin-top: 16rpx;
  padding: 12rpx 16rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #666;
  line-height: 1.5;
}

.import-hint--warning {
  color: #e37318;
}

/* Tab4: 设置 */
.profile-card {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 40rpx 32rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 20rpx;
}

.avatar-btn {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  padding: 0;
  margin: 0 28rpx 0 0;
  border: none;
  background: transparent;
  border-radius: 50%;
  overflow: visible;
  line-height: normal;
  flex-shrink: 0;
}

.avatar-btn::after {
  display: none;
}

.profile-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
}

.profile-avatar--placeholder {
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-edit-badge {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.profile-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}

.profile-name-input {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  width: 100%;
}

.section-title {
  font-size: 26rpx;
  color: #999;
  padding: 20rpx 0 12rpx 8rpx;
}

.logout-cell {
  --td-cell-title-color: #d54941;
}

.danger-cell {
  --td-cell-title-color: #d54941;
}

.footer-hint {
  text-align: center;
  font-size: 24rpx;
  color: #bbb;
  padding: 48rpx 0;
}

.rebind-body {
  padding: 16rpx 24rpx;
}

.rebind-hint {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.rebind-error {
  font-size: 24rpx;
  color: #d54941;
  margin-top: 12rpx;
}

.edit-popup__picker {
  padding: 16rpx 24rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  color: #333;
  font-size: 28rpx;
}

/* 编辑学生信息弹窗 */
.edit-popup {
  width: 100%;
  height: 85vh;
  background: #fff;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.edit-popup__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 24rpx;
  border-bottom: 1rpx solid #e0e0e0;
  flex-shrink: 0;
  box-sizing: border-box;
}

.edit-popup__title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.edit-popup__close {
  padding: 8rpx;
  cursor: pointer;
  flex-shrink: 0;
}

.edit-popup__body {
  flex: 1;
  padding: 32rpx;
  overflow-y: scroll;
  -webkit-overflow-scrolling: touch;
  box-sizing: border-box;
  width: 100%;
}

.edit-popup__section {
  margin-bottom: 48rpx;
  width: 100%;
  box-sizing: border-box;
}

.edit-popup__section:last-of-type {
  margin-bottom: 32rpx;
}

.edit-popup__section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid #e0e0e0;
  width: 100%;
  box-sizing: border-box;
}

.edit-popup__field {
  margin-bottom: 32rpx;
  width: 100%;
  box-sizing: border-box;
}

.edit-popup__label {
  display: block;
  font-size: 28rpx;
  color: #666;
  font-weight: 600;
  margin-bottom: 16rpx;
  width: 100%;
  box-sizing: border-box;
}

.edit-popup__date {
  padding: 24rpx 32rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  border: 1rpx solid #e0e0e0;
  width: 100%;
  box-sizing: border-box;
  word-break: break-all;
  cursor: pointer;
  user-select: none;
  -webkit-tap-highlight-color: rgba(0, 0, 0, 0.1);
}

.edit-popup__picker {
  padding: 24rpx 32rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  border: 1rpx solid #e0e0e0;
  width: 100%;
  box-sizing: border-box;
  word-break: break-all;
}

.edit-popup__date:active {
  background: #e8e8e8;
}

.edit-popup__actions {
  margin-top: 48rpx;
  padding-top: 32rpx;
}

/* 楼栋管理对话框 */
.building-manage-body {
  padding: 20rpx 0;
}

.building-list {
  max-height: 400rpx;
  overflow-y: auto;
}

.building-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.building-item:last-child {
  border-bottom: none;
}

.building-item__info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.building-item__name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.building-item__stats {
  font-size: 24rpx;
  color: #999;
}

.building-item__actions {
  display: flex;
  gap: 12rpx;
}

.building-add {
  padding: 24rpx 32rpx 0;
  border-top: 1rpx solid #f0f0f0;
  margin-top: 16rpx;
}

/* 学生详情对话框 */
.detail-dialog-body {
  padding: 16rpx 24rpx;
  max-height: 70vh;
  overflow-y: auto;
}

.detail-dialog-section {
  margin-bottom: 24rpx;
}

.detail-dialog-section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  padding-bottom: 8rpx;
  border-bottom: 1rpx solid #e0e0e0;
}

.detail-dialog-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.detail-dialog-row:last-child {
  border-bottom: none;
}

.detail-dialog-label {
  font-size: 26rpx;
  color: #999;
  min-width: 140rpx;
  flex-shrink: 0;
}

.detail-dialog-value {
  font-size: 28rpx;
  color: #333;
  text-align: right;
  flex: 1;
  word-break: break-all;
  margin-left: 16rpx;
}

.detail-dialog-empty {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 26rpx;
}

.detail-dialog-actions {
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #e0e0e0;
}

/* Tab3: 学生总览 */
.student-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.student-card {
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  cursor: pointer;
  transition: background-color 0.2s;
}

.student-card:active {
  background-color: #f5f5f5;
}

.student-card:last-child {
  border-bottom: none;
}

.student-card__info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.student-card__left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.student-card__name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.student-card__gender {
  font-size: 24rpx;
  color: #666;
  padding: 4rpx 12rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.student-card__room {
  font-size: 26rpx;
  color: #666;
}

.student-card__room--empty {
  color: #999;
}
