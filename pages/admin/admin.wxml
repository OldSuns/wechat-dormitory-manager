<t-navbar title="管理后台" />

<view class="page">
  <t-tabs defaultValue="{{0}}" bind:change="onTabChange" t-class="admin-tabs">
    <t-tab-panel label="楼层概览" value="{{0}}" />
    <t-tab-panel label="房间管理" value="{{1}}" />
    <t-tab-panel label="学生总览" value="{{2}}" />
    <t-tab-panel label="设置" value="{{3}}" />
    <t-tab-panel label="申请审批" value="{{4}}" />
  </t-tabs>

  <!-- Tab 1: 楼层概览 -->
  <view wx:if="{{currentTab === 0}}">
    <t-tabs defaultValue="{{0}}" bind:change="onFloorTabChange" t-class="floor-tabs">
      <t-tab-panel wx:for="{{floors}}" wx:key="*this" label="{{item}}F" value="{{index}}" />
    </t-tabs>

    <view class="summary-bar">
      <view class="summary-item">
        <text class="summary-value">{{floorSummary.totalRooms}}</text>
        <text class="summary-label">房间</text>
      </view>
      <view class="summary-item">
        <text class="summary-value">{{floorSummary.totalBeds}}</text>
        <text class="summary-label">总床位</text>
      </view>
      <view class="summary-item">
        <text class="summary-value summary-value--green">{{floorSummary.emptyBeds}}</text>
        <text class="summary-label">空床</text>
      </view>
      <view class="summary-item" wx:if="{{floorSummary.leavingSoonCount > 0}}">
        <text class="summary-value summary-value--orange">{{floorSummary.leavingSoonCount}}</text>
        <text class="summary-label">即将退宿</text>
      </view>
    </view>

    <view class="room-grid">
      <view class="room-grid__item" wx:for="{{rooms}}" wx:key="roomId">
        <room-card room="{{item}}" summary="{{roomSummaries[item.roomId]}}" bind:roomtap="onRoomTap" />
      </view>
    </view>
    <view wx:if="{{rooms.length === 0}}" class="empty-hint"><text>该楼层暂无房间</text></view>
  </view>

  <!-- Tab 2: 房间管理 -->
  <view wx:if="{{currentTab === 1}}" class="tab-content">
    <view class="mgmt-header">
      <t-button theme="primary" size="small" icon="add" bindtap="onShowAddDialog">添加房间</t-button>
    </view>

    <view class="room-list">
      <t-swipe-cell
        wx:for="{{allRooms}}"
        wx:key="roomId"
        right="{{[{text: '编辑', className: 'btn-edit'}, {text: '删除', className: 'btn-delete'}]}}"
        bind:click="onRoomSwipeAction"
        data-roomid="{{item.roomId}}"
      >
        <view class="room-mgmt-cell">
          <view class="room-mgmt-cell__left">
            <text class="room-mgmt-cell__name">{{item.roomNumber}}号</text>
            <text class="room-mgmt-cell__floor">{{item.floor}}F</text>
          </view>
          <view class="room-mgmt-cell__right">
            <text class="room-mgmt-cell__bed-info">{{item.occupiedCount}}/{{item.beds.length}}</text>
            <text class="room-mgmt-cell__label">已住/总床位</text>
          </view>
        </view>
      </t-swipe-cell>
    </view>
  </view>

  <!-- Tab 3: 学生总览 -->
  <view wx:if="{{currentTab === 2}}" class="tab-content">
    <view class="summary-bar">
      <view class="summary-item">
        <text class="summary-value">{{studentSummary.totalStudents}}</text>
        <text class="summary-label">学生总数</text>
      </view>
      <view class="summary-item">
        <text class="summary-value summary-value--green">{{studentSummary.occupiedBeds}}</text>
        <text class="summary-label">已入住</text>
      </view>
      <view class="summary-item">
        <text class="summary-value">{{studentSummary.unassigned}}</text>
        <text class="summary-label">未入住</text>
      </view>
    </view>

    <view class="student-list">
      <view class="student-card" wx:for="{{students}}" wx:key="studentId" bindtap="onStudentTap" data-studentid="{{item.studentId}}">
        <view class="student-card__info">
          <view class="student-card__left">
            <text class="student-card__name">{{item.name}}</text>
            <text class="student-card__gender">{{item.gender}}</text>
          </view>
          <text class="student-card__room" wx:if="{{item.roomInfo}}">{{item.roomInfo}}</text>
          <text class="student-card__room student-card__room--empty" wx:else>未入住</text>
        </view>
      </view>
    </view>

    <t-empty wx:if="{{students.length === 0}}" description="暂无学生数据" />
  </view>

  <!-- Tab 4: 申请审批 -->
  <view wx:if="{{currentTab === 4}}" class="tab-content">
    <view wx:if="{{pendingCount > 0}}" class="app-count-hint">
      <text>待处理 {{pendingCount}} 条申请</text>
    </view>

    <application-card
      wx:for="{{pendingApps}}"
      wx:key="applicationId"
      application="{{item}}"
      showActions="{{true}}"
      bind:approve="onApprove"
      bind:reject="onReject"
    />

    <t-empty wx:if="{{pendingApps.length === 0}}" description="暂无待审批申请" />
  </view>

  <!-- Tab 5: 设置 -->
  <view wx:if="{{currentTab === 3}}" class="tab-content">
    <view class="profile-card" wx:if="{{currentUser}}">
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image class="profile-avatar" src="{{currentUser.avatarUrl}}" mode="aspectFill" wx:if="{{currentUser.avatarUrl}}" />
        <view class="profile-avatar profile-avatar--placeholder" wx:else>
          <t-icon name="user" size="64rpx" color="#999" />
        </view>
        <view class="avatar-edit-badge">
          <t-icon name="camera" size="24rpx" color="#fff" />
        </view>
      </button>
      <view class="profile-info">
        <input class="profile-name-input" type="nickname" placeholder="点击设置昵称" value="{{currentUser.nickName || currentUser.name}}" bindblur="onNicknameBlur" bindconfirm="onNicknameConfirm" />
        <t-tag variant="light" theme="warning" size="small">管理员</t-tag>
      </view>
    </view>

    <view class="section-title">账号信息</view>
    <t-cell-group bordered>
      <t-cell title="姓名" note="{{currentUser.name}}" />
      <t-cell title="工号" note="{{currentUser.studentId}}" arrow hover bind:click="onEditStudentId" />
      <t-cell title="手机号" note="{{currentUser.phone || '未设置'}}" arrow hover bind:click="onEditPhone" />
    </t-cell-group>

    <view class="section-title">数据管理</view>
    <t-cell-group bordered>
      <t-cell title="导出数据" note="导出Excel文件" arrow hover bind:click="onExportAll" />
      <t-cell title="导入数据" note="从Excel导入" arrow hover bind:click="onShowImportDialog" />
      <t-cell title="下载导入模板" note="含示例和说明" arrow hover bind:click="onDownloadTemplate" />
      <t-cell title="清空所有数据" note="高危操作" arrow hover bind:click="onShowClearDataDialog" t-class="danger-cell" />
    </t-cell-group>

    <view class="section-title">账号操作</view>
    <t-cell-group bordered>
      <t-cell title="退出登录" arrow hover bind:click="onShowLogout" t-class="logout-cell" />
    </t-cell-group>
  </view>
</view>

<!-- 导入数据弹窗 -->
<t-dialog
  visible="{{showImportDialog}}"
  title="导入数据"
  confirmBtn="选择文件"
  cancelBtn="取消"
  bind:confirm="onChooseImportFile"
  bind:cancel="onImportDialogClose"
>
  <view slot="content" class="import-dialog-body">
    <view class="import-mode-label">导入模式</view>
    <t-radio-group value="{{importMode}}" bind:change="onImportModeChange">
      <t-radio value="merge" label="合并模式" />
      <t-radio value="replace" label="替换模式" />
    </t-radio-group>
    <view class="import-hint">
      <text wx:if="{{importMode === 'merge'}}">合并模式: 添加新记录,更新已存在的记录</text>
      <text wx:if="{{importMode === 'replace'}}" class="import-hint--warning">替换模式: 清空现有数据后导入(谨慎使用)</text>
    </view>
  </view>
</t-dialog>

<!-- 添加房间弹窗 -->
<t-dialog
  visible="{{showAddDialog}}"
  title="添加房间"
  confirmBtn="确认添加"
  cancelBtn="取消"
  bind:confirm="onConfirmAddRoom"
  bind:cancel="onAddDialogClose"
>
  <view slot="content" class="add-dialog-body">
    <view class="add-dialog-field">
      <text class="add-dialog-label">楼层</text>
      <t-input placeholder="如 3" type="number" value="{{addFloor}}" bindchange="onAddFloorInput" />
    </view>
    <view class="add-dialog-field">
      <text class="add-dialog-label">房间号</text>
      <t-input placeholder="如 105" value="{{addRoomNumber}}" bindchange="onAddRoomNumberInput" />
    </view>
    <view class="add-dialog-field">
      <text class="add-dialog-label">床位数</text>
      <t-stepper value="{{addBedCount}}" min="{{1}}" max="{{8}}" bind:change="onAddBedCountChange" />
    </view>
  </view>
</t-dialog>


<!-- 编辑房间弹窗 -->
<t-dialog
  visible="{{showEditRoomDialog}}"
  title="编辑房间"
  confirmBtn="确认保存"
  cancelBtn="取消"
  bind:confirm="onConfirmEditRoom"
  bind:cancel="onEditRoomDialogClose"
>
  <view slot="content" class="edit-dialog-body">
    <view class="add-dialog-field">
      <text class="add-dialog-label">楼层</text>
      <t-input placeholder="如 3" type="number" value="{{editRoomFloor}}" bindchange="onEditRoomFloorInput" />
    </view>
    <view class="add-dialog-field">
      <text class="add-dialog-label">房间号</text>
      <t-input placeholder="如 105" value="{{editRoomNumber}}" bindchange="onEditRoomNumberInput" />
    </view>
    <view class="add-dialog-field">
      <text class="add-dialog-label">床位数</text>
      <t-stepper value="{{editRoomBedCount}}" min="{{1}}" max="{{8}}" bind:change="onEditRoomBedCountChange" />
    </view>
  </view>
</t-dialog>


<!-- 退出确认 -->
<t-dialog
  visible="{{showLogoutDialog}}"
  title="退出登录"
  content="确认退出当前账号？下次进入需重新登录绑定。"
  confirmBtn="确认退出"
  cancelBtn="取消"
  bind:confirm="onLogoutConfirm"
  bind:cancel="onLogoutCancel"
/>

<!-- 修改手机号 -->
<t-dialog
  visible="{{showEditPhoneDialog}}"
  title="修改手机号"
  confirmBtn="保存"
  cancelBtn="取消"
  bind:confirm="onEditPhoneConfirm"
  bind:cancel="onEditPhoneCancel"
>
  <view slot="content" class="edit-dialog-body">
    <t-input placeholder="请输入手机号" type="number" maxlength="{{11}}" value="{{editPhone}}" bindchange="onEditPhoneInput" clearable />
  </view>
</t-dialog>

<!-- 修改工号 -->
<t-dialog
  visible="{{showEditStudentIdDialog}}"
  title="修改工号"
  confirmBtn="保存"
  cancelBtn="取消"
  bind:confirm="onEditStudentIdConfirm"
  bind:cancel="onEditStudentIdCancel"
>
  <view slot="content" class="edit-dialog-body">
    <t-input placeholder="请输入工号" value="{{editStudentId}}" bindchange="onEditStudentIdInput" clearable />
  </view>
</t-dialog>

<!-- 清空数据确认 -->
<t-dialog
  visible="{{showClearDataDialog}}"
  title="清空所有数据"
  content="此操作将删除所有房间、入住信息、申请记录和其他用户数据，但会保留您的管理员账号。此操作不可恢复，确认继续？"
  confirmBtn="确认清空"
  cancelBtn="取消"
  bind:confirm="onClearDataConfirm"
  bind:cancel="onClearDataCancel"
/>

<!-- 学生详情对话框 -->
<t-dialog
  visible="{{showStudentDetailDialog}}"
  title="学生详情"
  confirmBtn="关闭"
  bind:confirm="onStudentDetailDialogClose"
>
  <view slot="content" class="detail-dialog-body">
    <view class="detail-dialog-section">
      <view class="detail-dialog-row">
        <text class="detail-dialog-label">姓名</text>
        <text class="detail-dialog-value">{{viewingStudent.name}}</text>
      </view>
      <view class="detail-dialog-row">
        <text class="detail-dialog-label">性别</text>
        <text class="detail-dialog-value">{{viewingStudent.gender}}</text>
      </view>
      <view class="detail-dialog-row">
        <text class="detail-dialog-label">学号/工号</text>
        <text class="detail-dialog-value">{{viewingStudent.studentId}}</text>
      </view>
      <view class="detail-dialog-row">
        <text class="detail-dialog-label">人员类型</text>
        <text class="detail-dialog-value">{{viewingStudent.type}}</text>
      </view>
      <view class="detail-dialog-row">
        <text class="detail-dialog-label">手机号</text>
        <text class="detail-dialog-value">{{viewingStudent.phone || '未设置'}}</text>
      </view>
    </view>

    <view class="detail-dialog-section" wx:if="{{viewingStudentRoom}}">
      <view class="detail-dialog-section-title">住宿信息</view>
      <view class="detail-dialog-row">
        <text class="detail-dialog-label">房间</text>
        <text class="detail-dialog-value">{{viewingStudentRoom.floor}}F-{{viewingStudentRoom.roomNumber}}号-{{viewingStudentRoom.bedNo}}床</text>
      </view>
      <view class="detail-dialog-row">
        <text class="detail-dialog-label">入住日期</text>
        <text class="detail-dialog-value">{{viewingStudentRoom.checkInDate || '未设置'}}</text>
      </view>
      <view class="detail-dialog-row">
        <text class="detail-dialog-label">预计退宿</text>
        <text class="detail-dialog-value">{{viewingStudentRoom.expectedLeaveDate || '未设置'}}</text>
      </view>
    </view>

    <view class="detail-dialog-section" wx:else>
      <view class="detail-dialog-empty">该学生暂未入住</view>
    </view>

    <view class="detail-dialog-actions">
      <t-button theme="primary" size="medium" block catchtap="onShowEditStudent">编辑学生信息</t-button>
    </view>
  </view>
</t-dialog>

<!-- 编辑学生信息弹窗 -->
<t-popup visible="{{showEditStudentDialog}}" placement="bottom" z-index="{{11500}}" bind:visible-change="onEditStudentPopupChange">
  <view class="edit-popup">
    <view class="edit-popup__header">
      <text class="edit-popup__title">编辑学生信息</text>
      <view class="edit-popup__close" bindtap="onEditStudentDialogClose">
        <t-icon name="close" size="44rpx" />
      </view>
    </view>

    <scroll-view scroll-y class="edit-popup__body">
      <view class="edit-popup__section">
        <view class="edit-popup__section-title">基本信息</view>

        <view class="edit-popup__field">
          <text class="edit-popup__label">姓名 *</text>
          <t-input placeholder="请输入姓名" value="{{editStudentForm.name}}" bindchange="onEditStudentNameInput" clearable />
        </view>

        <view class="edit-popup__field">
          <text class="edit-popup__label">性别 *</text>
          <t-radio-group value="{{editStudentForm.gender}}" bind:change="onEditStudentGenderChange">
            <t-radio value="男" label="男" />
            <t-radio value="女" label="女" />
          </t-radio-group>
        </view>

        <view class="edit-popup__field">
          <text class="edit-popup__label">人员类型 *</text>
          <t-radio-group value="{{editStudentForm.type}}" bind:change="onEditStudentTypeChange">
            <t-radio value="本科生" label="本科生" />
            <t-radio value="研究生" label="研究生" />
            <t-radio value="实习生" label="实习生" />
          </t-radio-group>
        </view>

        <view class="edit-popup__field">
          <text class="edit-popup__label">手机号</text>
          <t-input placeholder="请输入手机号" type="number" maxlength="{{11}}" value="{{editStudentForm.phone}}" bindchange="onEditStudentPhoneInput" clearable />
        </view>
      </view>

      <view class="edit-popup__section" wx:if="{{editStudentForm.hasRoom}}">
        <view class="edit-popup__section-title">住宿信息</view>

        <view class="edit-popup__field">
          <text class="edit-popup__label">房间床位</text>
          <picker mode="multiSelector" range="{{bedPickerColumns}}" range-key="label" value="{{bedPickerValue}}" bindchange="onBedPickerChange" bindcolumnchange="onBedPickerColumnChange">
            <view class="edit-popup__picker">
              <text>{{selectedBedLabel || '点击选择房间和床位'}}</text>
            </view>
          </picker>
        </view>

        <view class="edit-popup__field">
          <text class="edit-popup__label">入住日期</text>
          <view class="edit-popup__date" catchtap="onOpenCheckInPicker">
            <text>{{editStudentForm.checkInDate || '点击选择日期'}}</text>
          </view>
        </view>

        <view class="edit-popup__field">
          <text class="edit-popup__label">预计退宿日期</text>
          <view class="edit-popup__date" catchtap="onOpenLeavePicker">
            <text>{{editStudentForm.expectedLeaveDate || '点击选择日期（可选）'}}</text>
          </view>
        </view>
      </view>

      <view class="edit-popup__actions">
        <t-button theme="default" size="large" block bindtap="onEditStudentDialogClose">取消</t-button>
        <t-button theme="primary" size="large" block bindtap="onEditStudentConfirm" style="margin-top: 16rpx;">保存</t-button>
      </view>
    </scroll-view>
  </view>
</t-popup>

<!-- 性别冲突确认对话框 -->
<t-dialog
  visible="{{showGenderConflictDialog}}"
  title="性别冲突提示"
  content="{{genderConflictMsg}}"
  confirmBtn="确认换入"
  cancelBtn="取消"
  bind:confirm="onConfirmGenderConflict"
  bind:cancel="onCancelGenderConflict"
/>

<!-- 入住日期选择器 -->
<t-date-time-picker
  title="选择入住日期"
  visible="{{showCheckInPicker}}"
  mode="date"
  value="{{editStudentForm.checkInDate}}"
  format="YYYY-MM-DD"
  bindconfirm="onCheckInDateConfirm"
  bindcancel="onCheckInDateCancel"
/>

<!-- 退宿日期选择器 -->
<t-date-time-picker
  title="选择退宿日期"
  visible="{{showLeavePicker}}"
  mode="date"
  value="{{editStudentForm.expectedLeaveDate}}"
  format="YYYY-MM-DD"
  bindconfirm="onLeaveDateConfirm"
  bindcancel="onLeaveDateCancel"
/>
